# ============================================================
# LegalRisk-LLM Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# Anthropic API key (for data generation in Phase 1C and LLM judge in Phase 3B)
ANTHROPIC_API_KEY=your_api_key_here

# Optional: HuggingFace token (for accessing gated models)
# HF_TOKEN=your_hf_token_here

# Optional: Weights and Biases API key (for training experiment tracking)
# WANDB_API_KEY=your_wandb_key_here
# WANDB_PROJECT=legalrisk-llm

# Optional: override model path if using a local mirror
# BASE_MODEL=unsloth/Meta-Llama-3.2-3B-Instruct
