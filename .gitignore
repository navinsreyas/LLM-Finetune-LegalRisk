# ML model weights (large files -- do not commit)
models/
*.pt
*.pth
*.bin
*.safetensors
*.gguf
*.ggml

# Data files (large -- do not commit CUAD raw data)
data/CUAD_v1.json
data/raw_clauses.jsonl
data/synthetic/
*.jsonl

# Reproducibility exception: un-ignore ONLY the pre-generated evaluation inputs that
# phases 3C/3D/4 read (evaluation/*_predictions.jsonl + judge_scores/*_judge_scores.jsonl),
# so "reproduce without training" works from a fresh clone. All other *.jsonl stay ignored.
!evaluation/qlora_predictions.jsonl
!evaluation/dora_predictions.jsonl
!evaluation/ia3_predictions.jsonl
!evaluation/rag_predictions.jsonl
!evaluation/judge_scores/qlora_judge_scores.jsonl
!evaluation/judge_scores/dora_judge_scores.jsonl
!evaluation/judge_scores/ia3_judge_scores.jsonl
!evaluation/judge_scores/rag_judge_scores.jsonl

# Experiment tracking
wandb/
mlruns/
.wandb/

# Vector store data (ChromaDB)
chromadb/
chroma/

# Personal reference (not for public repo)
for_me.md

# Logs
*.log
logs/

# Misc
*.csv
.ipynb_checkpoints/
tmp/
.tmp

# Study and personal documents (private, do not publish)
study/

# Worklog / audit notes (private, do not publish)
notes/

# API key files (sensitive -- never commit)
*.txt
!requirements.txt
!dashboard/requirements.txt
* api key*.txt
llama api key.txt
weights and biases api key.txt

# ChromaDB vector store (data/rag/)
data/rag/
chroma_db/

